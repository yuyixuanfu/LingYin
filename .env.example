# 聆音 LingYin 配置
# 拷一份改成 .env 填上你的 key

# ASR 走小米 MiMo(国内直连,base64多模态chat接口)
# 注册: https://api.xiaomimimo.com
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_MODEL=mimo-v2.5-asr

# 听觉感知走 DeepSeek(国内直连,便宜)
# 注册: https://platform.deepseek.com
DS_API_KEY=
DS_BASE_URL=https://api.deepseek.com/v1
DS_MODEL=deepseek-v4-flash

# 基线文件(说话人的"平时",攒够8条出"和平时比")
LINGYIN_BASELINE_FILE=
