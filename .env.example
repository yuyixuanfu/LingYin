# 聆音 LingYin 配置
# 拷一份改成 .env 填上你的 key
#
# 转写(ASR)和听觉感知(LLM)都可以换成任意 OpenAI 兼容接口。
# 下面默认用 MiMo(国内直连免梯子)+DeepSeek(国内直连便宜)。
# 你也可以换成 OpenAI / 硅基流动 / 千问 / Groq / 本地 vLLM 等,
# 只要接口是 OpenAI 兼容(/v1/chat/completions)即可。

# ── ASR 转写 ──
# 默认:小米 MiMo(国内直连)。注意 MiMo 的 ASR 走 chat 多模态接口(音频塞 input_audio),
#       不是标准 /audio/transcriptions。lingyin.py 会按 ASR_PROVIDER 自动选接口。
ASR_PROVIDER=mimo          # mimo(多模态chat) 或 openai(标准/audio/transcriptions)
ASR_API_KEY=
ASR_BASE_URL=https://api.xiaomimimo.com/v1
ASR_MODEL=mimo-v2.5-asr
ASR_LANG=zh

# ── 听觉感知 LLM ──
# 默认:DeepSeek(国内直连,便宜)。任意 OpenAI 兼容 LLM 都行。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# ── 基线文件(说话人的"平时") ──
# 攒够8条出"和平时比"。多人各跑实例指到不同文件。
LINGYIN_BASELINE_FILE=
